<Window x:Class="hylogparser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:hylogparser"
        Title="hylogparser — ATM Log Parser" 
        Width="640" Height="680"
        MinWidth="580" MinHeight="580"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Input file -->
            <RowDefinition Height="Auto"/>   <!-- View groups -->
            <RowDefinition Height="Auto"/>   <!-- Options -->
            <RowDefinition Height="Auto"/>   <!-- Buttons -->
            <RowDefinition Height="*"/>      <!-- Output log -->
            <RowDefinition Height="Auto"/>   <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ============================================================ -->
        <!--  ROW 0: Input file                                           -->
        <!-- ============================================================ -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Log Archive (.zip) or Folder" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="txtInputFile" Grid.Column="0" 
                         VerticalContentAlignment="Center" Padding="6,4"
                         AllowDrop="True" Drop="Window_Drop" DragOver="Window_DragOver"/>
                <Button x:Name="btnBrowse" Grid.Column="1" Content="Browse…" 
                        Margin="8,0,0,0" Padding="12,4" Click="btnBrowse_Click"/>
            </Grid>
        </StackPanel>

        <!-- ============================================================ -->
        <!--  ROW 1: Three-column view selection                          -->
        <!-- ============================================================ -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- AP Views -->
            <GroupBox Grid.Column="0">
                <GroupBox.Header>
                    <DockPanel>
                        <TextBlock Text="Application Logs (-a)" FontWeight="SemiBold" DockPanel.Dock="Left"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="All" Style="{StaticResource SubtleButton}" Click="btnAPAll_Click"/>
                            <TextBlock Text="·" Margin="4,0" VerticalAlignment="Center" Foreground="Gray"/>
                            <Button Content="None" Style="{StaticResource SubtleButton}" Click="btnAPNone_Click"/>
                        </StackPanel>
                    </DockPanel>
                </GroupBox.Header>
                <ItemsControl x:Name="icAPViews"/>
            </GroupBox>

            <!-- SP Views -->
            <GroupBox Grid.Column="2">
                <GroupBox.Header>
                    <DockPanel>
                        <TextBlock Text="Service Provider (-s)" FontWeight="SemiBold" DockPanel.Dock="Left"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="All" Style="{StaticResource SubtleButton}" Click="btnSPAll_Click"/>
                            <TextBlock Text="·" Margin="4,0" VerticalAlignment="Center" Foreground="Gray"/>
                            <Button Content="None" Style="{StaticResource SubtleButton}" Click="btnSPNone_Click"/>
                        </StackPanel>
                    </DockPanel>
                </GroupBox.Header>
                <ItemsControl x:Name="icSPViews"/>
            </GroupBox>

            <!-- Other Views -->
            <GroupBox Grid.Column="4">
                <GroupBox.Header>
                    <DockPanel>
                        <TextBlock Text="Other Logs" FontWeight="SemiBold" DockPanel.Dock="Left"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="All" Style="{StaticResource SubtleButton}" Click="btnOtherAll_Click"/>
                            <TextBlock Text="·" Margin="4,0" VerticalAlignment="Center" Foreground="Gray"/>
                            <Button Content="None" Style="{StaticResource SubtleButton}" Click="btnOtherNone_Click"/>
                        </StackPanel>
                    </DockPanel>
                </GroupBox.Header>
                <ItemsControl x:Name="icOtherViews"/>
            </GroupBox>
        </Grid>

        <!-- ============================================================ -->
        <!--  ROW 2: Options                                              -->
        <!-- ============================================================ -->
        <GroupBox Grid.Row="2" Margin="0,0,0,8">
            <GroupBox.Header>
                <TextBlock Text="Options" FontWeight="SemiBold"/>
            </GroupBox.Header>
            <WrapPanel VerticalAlignment="Center">
                <TextBlock Text="Start time" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox x:Name="txtTimeStart" Width="130" Padding="4,3" Margin="0,0,16,0"
                         ToolTip="Format: yyyyMMddhhmm (e.g. 202601231200)"/>
                <TextBlock Text="Span (min)" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox x:Name="txtTimeSpan" Width="60" Padding="4,3" Margin="0,0,16,0"/>
                <CheckBox x:Name="chkRawLogLine" Content="Include raw log lines" VerticalAlignment="Center"/>
            </WrapPanel>
        </GroupBox>

        <!-- ============================================================ -->
        <!--  ROW 3: Run / Cancel                                         -->
        <!-- ============================================================ -->
        <Grid Grid.Row="3" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="btnRun" Grid.Column="0" Content="Run" 
                    Style="{StaticResource AccentButton}" Click="btnRun_Click"
                    MinWidth="90"/>
            <Button x:Name="btnCancel" Grid.Column="1" Content="Cancel" 
                    Margin="8,0,0,0" Padding="16,6" IsEnabled="False" Click="btnCancel_Click"/>
            <TextBlock x:Name="lblStatus" Grid.Column="2" Text="Ready" 
                       VerticalAlignment="Center" Margin="12,0,0,0" Foreground="Gray"/>
            <TextBlock x:Name="lblVersion" Grid.Column="3" 
                       VerticalAlignment="Center" Foreground="LightGray" FontSize="11"/>
        </Grid>

        <!-- ============================================================ -->
        <!--  ROW 4: Output console                                       -->
        <!-- ============================================================ -->
        <Border Grid.Row="4" Background="#1E1E1E" CornerRadius="4" Padding="2">
            <TextBox x:Name="txtOutput" 
                     IsReadOnly="True" 
                     TextWrapping="NoWrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     Background="#1E1E1E" Foreground="#CCCCCC"
                     BorderThickness="0"
                     FontFamily="Cascadia Mono, Consolas, Courier New"
                     FontSize="12"
                     Padding="6"/>
        </Border>

        <!-- ============================================================ -->
        <!--  ROW 5: Status bar                                           -->
        <!-- ============================================================ -->
        <TextBlock Grid.Row="5" x:Name="lblDragHint" 
                   Text="Tip: drag &amp; drop a .zip file anywhere on this window"
                   Foreground="LightGray" FontSize="11" Margin="0,6,0,0"/>
    </Grid>
</Window>
