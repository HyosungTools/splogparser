  <!-- error : XFS CIM error codes (xfscim.h, CIM_SERVICE_OFFSET = 1300) -->

  <Messages>
    <type>error</type>
    <code>-1300</code>
    <brief>invalid currency</brief>
    <description>There are no cash units of the currency specified.</description>
  </Messages>

  <Messages>
    <type>error</type>
    <code>-1301</code>
    <brief>invalid teller id</brief>
    <description>The teller ID is not valid.</description>
  </Messages>

  <Messages>
    <type>error</type>
    <code>-1302</code>
    <brief>cash unit error</brief>
    <description>There is a problem with a cash unit. A WFS_EXEE_CIM_CASHUNITERROR event will be posted with the details.</description>
  </Messages>

  <Messages>
    <type>error</type>
    <code>-1307</code>
    <brief>too many items</brief>
    <description>There were too many items inserted. The cash-in stacker is full.</description>
  </Messages>

  <Messages>
    <type>error</type>
    <code>-1308</code>
    <brief>unsup position</brief>
    <description>The specified position is not supported.</description>
  </Messages>

  <Messages>
    <type>error</type>
    <code>-1310</code>
    <brief>safedoor open</brief>
    <description>The safe door is open. This device requires the safe door to be closed in order to perform this operation.</description>
  </Messages>

  <Messages>
    <type>error</type>
    <code>-1312</code>
    <brief>shutter not open</brief>
    <description>The shutter is not open or did not open when it should have.</description>
  </Messages>

  <Messages>
    <type>error</type>
    <code>-1313</code>
    <brief>shutter open</brief>
    <description>The shutter is open when it should be closed.</description>
  </Messages>

  <Messages>
    <type>error</type>
    <code>-1314</code>
    <brief>shutter closed</brief>
    <description>The shutter was already closed / is closed when it should be open.</description>
  </Messages>

  <Messages>
    <type>error</type>
    <code>-1315</code>
    <brief>invalid cash unit</brief>
    <description>The cash unit number specified is not valid.</description>
  </Messages>

  <Messages>
    <type>error</type>
    <code>-1316</code>
    <brief>no items</brief>
    <description>There were no items to cash in / no items on the stacker.</description>
  </Messages>

  <Messages>
    <type>error</type>
    <code>-1317</code>
    <brief>exchange active</brief>
    <description>The CIM is in an exchange state.</description>
  </Messages>

  <Messages>
    <type>error</type>
    <code>-1318</code>
    <brief>no exchange active</brief>
    <description>There is no exchange active.</description>
  </Messages>

  <Messages>
    <type>error</type>
    <code>-1319</code>
    <brief>shutter not closed</brief>
    <description>The shutter failed to close.</description>
  </Messages>

  <Messages>
    <type>error</type>
    <code>-1323</code>
    <brief>items taken</brief>
    <description>Items were removed by the user before the operation completed.</description>
  </Messages>

  <Messages>
    <type>error</type>
    <code>-1325</code>
    <brief>cashin active</brief>
    <description>A cash-in transaction is active. The command is not allowed at this time.</description>
  </Messages>

  <Messages>
    <type>error</type>
    <code>-1326</code>
    <brief>no cashin active</brief>
    <description>There is no cash-in transaction active.</description>
  </Messages>

  <Messages>
    <type>error</type>
    <code>-1328</code>
    <brief>pos not empty</brief>
    <description>The input or output position is not empty.</description>
  </Messages>

  <Messages>
    <type>error</type>
    <code>-1334</code>
    <brief>invalid retract pos</brief>
    <description>The retract position (usIndex) specified is not valid.</description>
  </Messages>

  <Messages>
    <type>error</type>
    <code>-1335</code>
    <brief>not retract area</brief>
    <description>The retract area specified in usRetractArea is not supported.</description>
  </Messages>

  <Messages>
    <type>error</type>
    <code>-1336</code>
    <brief>invalid port</brief>
    <description>An attempt to set a guidance light to a new value was invalid because the guidance light does not exist.</description>
  </Messages>

  <Messages>
    <type>error</type>
    <code>-1337</code>
    <brief>foreign items</brief>
    <description>Foreign items have been detected in the input position.</description>
  </Messages>

  <Messages>
    <type>error</type>
    <code>-1338</code>
    <brief>load failed</brief>
